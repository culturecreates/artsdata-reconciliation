    {
      "@id": "http://lod.footlight.io/resource/68a631a602cc7e08336b5915",
      "@type": "EventSeries",
      "additionalType": [
        {
          "@id": "http://lod.footlight.io/resource/67e40b7d1088030064bef668",
          "@type": "skos:Concept",
