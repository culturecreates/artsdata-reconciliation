    {
      "@id": "http://lod.footlight.io/resource/68f15448c67759362763e738",
      "@type": "Event",
      "additionalType": [
        {
          "@id": "http://lod.footlight.io/resource/67e40b7d1088030064bef668",
          "@type": "skos:Concept",
          "skos:prefLabel": [
