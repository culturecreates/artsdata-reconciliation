@prefix adr:    <http://kg.artsdata.ca/resource/> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix schema: <http://schema.org/> .

adr:KP-1 a schema:Place ;
    rdfs:label "Place Bell" ;
    schema:name "Place Bell" .

adr:KP-2 a schema:Place ;
    rdfs:label "Place publique de la Place Bell" ;
    schema:name "Place publique de la Place Bell" .

adr:KP-3 a schema:Place ;
    rdfs:label "Place des Arts"@fr ;
    schema:name "Place des Arts"@fr ;
    schema:alternateName "Place des arts de Montréal" ;
    schema:address adr:KP3-address .

adr:KP3-address a schema:PostalAddress ;
    schema:postalCode "H2X 1Z8" ;
    schema:streetAddress "175, rue Sainte-Catherine Ouest" ;
    schema:addressLocality "Toronto" .

adr:KPR-1 a schema:Person ;
    rdfs:label "Persona bell" ;
     schema:name "Persona bell" .

adr:KO-1 a schema:Organization ;
    rdfs:label "Place Bell" ;
    schema:name "Place Bell" .