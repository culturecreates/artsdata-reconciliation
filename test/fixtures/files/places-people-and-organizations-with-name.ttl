@prefix adr:    <http://kg.artsdata.ca/resource/> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix schema: <http://schema.org/> .
@prefix dbo: <http://dbpedia.org/ontology/> .

# Places 

adr:KP-1 a schema:Place ;
    rdfs:label "Place Bell" ;
    schema:name "Place Bell" .

adr:KP-2 a schema:Place ;
    rdfs:label "Place publique de la Place Bell" ;
    schema:name "Place publique de la Place Bell" .

adr:KP-3 a schema:Place ;
    rdfs:label "Place des Arts"@fr ;
    schema:name "Place des Arts"@fr ;
    schema:alternateName "Place des arts de Montréal" ;
    schema:address adr:KP3-address .

adr:KP3-address a schema:PostalAddress ;
    schema:postalCode "H2X 1Z8" ;
    schema:streetAddress "175, rue Sainte-Catherine Ouest" ;
    schema:addressLocality "Toronto" .

adr:Place1 a schema:Place ;
    rdfs:label "Place 1" ;
    schema:name "Place 1" ;
    schema:alternateName "Alternate Name" .

# Persons

adr:KPR-1 a schema:Person , dbo:Agent ;
    rdfs:label "Persona bell" ;
     schema:name "Persona bell" .

adr:WarrenSonoda a schema:Person , dbo:Agent ;
    rdfs:label "Warren P. Sonoda" ;
     schema:name "Warren P. Sonoda" .

adr:GarretWillie a schema:Person , dbo:Agent ;
    rdfs:label "Garret T. Willie" ;
     schema:name "Garret T. Willie" .

adr:WarrenHoyano a schema:Person , dbo:Agent ;
    rdfs:label "Warren Hoyano" ;
     schema:name "Warren Hoyano" .


# Organizations

adr:KO-1 a schema:Organization , dbo:Agent ;
    rdfs:label "Place Bell" ;
    schema:name "Place Bell" .

